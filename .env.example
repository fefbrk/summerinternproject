# Backend URL
VITE_API_URL=http://localhost:3001

# Backend Security (server/.env or environment)
AUTH_TOKEN_SECRET=change_this_to_a_long_random_secret
AUTH_TOKEN_TTL_MS=86400000
AUTH_REFRESH_TOKEN_SECRET=change_this_to_a_long_random_refresh_secret
AUTH_REFRESH_TOKEN_TTL_MS=604800000
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
PII_ENCRYPTION_KEY=replace_with_32_byte_utf8_or_base64_or_hex
API_JSON_BODY_LIMIT=256kb
API_FORM_BODY_LIMIT=256kb
REGISTRATION_WINDOW_MS=900000
REGISTRATION_MAX_ATTEMPTS=20
REGISTRATION_RATE_LIMIT_MAX_ENTRIES=10000
LOGIN_LOCKOUT_WINDOW_MS=1800000
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_RATE_LIMIT_MAX_ENTRIES=50000
ENABLE_LOGIN_CAPTCHA=false
LOGIN_CAPTCHA_THRESHOLD=3
CAPTCHA_SECRET=replace_with_captcha_provider_secret
CAPTCHA_MIN_SCORE=0.5
SECURITY_ALERT_LOGIN_FAILURE_THRESHOLD=5
SECURITY_ALERT_ADMIN_WINDOW_MS=600000
SECURITY_ALERT_ADMIN_MUTATION_THRESHOLD=15
SECURITY_ALERT_BUSINESS_HOUR_START=8
SECURITY_ALERT_BUSINESS_HOUR_END=20
# Production: set unique admin email and strong password
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ReplaceWithStrongPass123A
ENABLE_DEMO_ENDPOINTS=false
CARRIER_WEBHOOK_SECRET=change_this_to_a_long_random_webhook_secret
CARRIER_WEBHOOK_WINDOW_MS=60000
CARRIER_WEBHOOK_MAX_ATTEMPTS=120
CARRIER_WEBHOOK_RATE_LIMIT_MAX_ENTRIES=50000
ENABLE_VIRUS_SCAN=false
VIRUS_SCAN_COMMAND=clamscan
VIRUS_SCAN_FAIL_OPEN=true
ENABLE_MANUAL_FULFILLMENT_OVERRIDE=false
ENABLE_MANUAL_PAYMENT_OVERRIDE=false
SUPER_ADMIN_EMAILS=admin@example.com
SQLITE_DB_PATH=./server/database/kinderlab.db
SQLITE_BACKUP_DIR=./server/database/backups
SQLITE_BACKUP_KEEP_COUNT=30
SQLITE_BACKUP_RETENTION_DAYS=30
SQLITE_BACKUP_ENCRYPTION_KEY=optional_32_byte_utf8_or_base64_or_hex

# Supabase Configuration (opsiyonel)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Configuration (opsiyonel)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
