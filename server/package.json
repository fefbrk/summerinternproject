{
  "name": "kinderlab-server",
  "version": "1.0.0",
  "description": "KinderLab Admin Backend Server",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "nodemon --exec \"node --env-file-if-exists=.env\" server.js",
    "migrate": "node migrate-data.js",
    "test": "node --test tests/api.integration.test.js tests/database.transaction.test.js tests/security.virusScan.test.js",
    "check:db-safety": "node scripts/checkTrackedDbSafety.js",
    "backup:db": "node --env-file-if-exists=.env scripts/backupDatabase.js",
    "restore:db": "node --env-file-if-exists=.env scripts/restoreDatabaseBackup.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.3",
    "fs-extra": "^11.1.1",
    "helmet": "^7.2.0",
    "multer": "^2.1.0",
    "sanitize-html": "^2.17.0",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "overrides": {
    "qs": "^6.14.1",
    "tar": "^7.5.8",
    "tar-fs": "^2.1.4",
    "node-gyp": "^10.3.2",
    "make-fetch-happen": "^14.0.3",
    "minimatch": "^3.1.4"
  }
}
